{
  "unstable": ["kv"],
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "vite",
    "dev:bypass": "DEV_BYPASS=true vite",
    "build": "vite build",
    "preview": "deno serve -A --unstable-kv _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "seed": "deno run -A --unstable-kv db/seed.ts",
    "brand:upgrade": "bash scripts/set-branding.sh upgrade",
    "brand:production": "bash scripts/set-branding.sh production"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*", "**/node_modules/*"],
  "imports": {
    "fresh": "jsr:@fresh/core@^2.2.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.4",
    "vite": "npm:vite@^7.0.0",
    "bcryptjs": "npm:bcryptjs@2.4.3",
    "@types/bcryptjs": "npm:@types/bcryptjs@2.4.6",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0"
  },
  "compilerOptions": { "jsx": "react-jsx", "jsxImportSource": "preact" }
}
