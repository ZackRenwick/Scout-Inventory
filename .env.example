# Copy this file to .env and adjust as needed.
# .env is gitignored and never committed.

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------

# Set to true to skip authentication when running on localhost.
# Remove or set to false to test the full auth flow locally.
DEV_BYPASS=true

# ---------------------------------------------------------------------------
# Production / Deno Deploy
# Configure these in Deno Deploy project settings — not in this file.
# ---------------------------------------------------------------------------

# Admin credentials (ADMIN_PASSWORD is REQUIRED in production).
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# Public URL of the deployed app (used in notification emails).
# APP_URL=https://example.co.uk

# Resend (https://resend.com) for email notifications.
# RESEND_API_KEY=
# NOTIFY_EMAIL=alerts@example.co.uk        # recipient address(es), comma-separated
# NOTIFY_FROM_EMAIL=noreply@example.co.uk  # sender address (must be a verified domain)

# Minimum necker stock level before a low-stock alert is sent.
# NECKER_MIN_THRESHOLD=10

# Cloudflare R2 photo storage (required for photo upload/serve/migration)
# R2_ACCOUNT_ID=
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Weekly inventory backup snapshots written into the same R2 bucket.
# ENABLE_INVENTORY_BACKUP_CRON=true
# INVENTORY_BACKUP_CRON=0 3 * * 0
# R2_BACKUP_PREFIX=backups/inventory
# INVENTORY_BACKUP_KEEP_COUNT=8
